{
  "//1": "Root workspace package — not published. Publishable packages live in packages/* (assistant, api, core, review, tools).",
  "name": "gaunt-sloth-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Gaunt Sloth Assistant workspace",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pukeko-robotics/gaunt-sloth.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build -w @gaunt-sloth/core && npm run build -w @gaunt-sloth/tools && npm run build -w @gaunt-sloth/api && npm run build -w @gaunt-sloth/review && npm run build -w gaunt-sloth-assistant",
    "unit": "vitest run",
    "test": "npm run build && vitest run",
    "it": "npm run build && node it.js",
    "it-verbose": "npm run build && GSLOTH_IT_VERBOSE=1 node it.js",
    "lint": "eslint . --ext .js,.ts",
    "lint-n-fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write 'packages/*/src/**/*.{js,ts}'",
    "prepare": "echo 'skipping prepare'",
    "typedoc": "typedoc",
    "chat": "node packages/assistant/cli.js",
    "release:bump": "node bump.mjs",
    "release:bump-and-commit": "node bump.mjs --commit",
    "release:tag": "./tag-packages.sh",
    "release:publish": "./publish-all.sh"
  },
  "//2": "Root workspace package — not published, holds dev dependencies. Publishable packages live in packages/* (assistant, api, core, review, tools).",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "rimraf": "^6.1.0",
    "minimatch": "^10.2.4",
    "uuid": ">=11.1.1"
  }
}
