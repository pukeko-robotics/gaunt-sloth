{
  "llm": {
    "type": "openrouter",
    "model": "anthropic/claude-opus-4.5:online"
  },
  "writeOutputToFile": false,
  "consoleLevel": "display",
  "canInterruptInferenceWithEsc": false,
  "commands": {
    "code": {
      "filesystem": "all",
      "builtInTools": {
        "gth_checklist": true,
        "run_shell_command": true,
        "run_build": { "command": "pnpm run build" },
        "run_tests": { "command": "pnpm test" },
        "run_lint": { "command": "pnpm run lint-n-fix" },
        "run_single_test": { "command": "pnpm test" }
      }
    }
  }
}
