{
  "llm": {
    "type": "anthropic",
    "model": "claude-opus-4-6"
  },
  "commands": {
    "code": {
      "filesystem": "all",
      "builtInTools": {
        "gth_checklist": true,
        "run_shell_command": true,
        "run_build": { "command": "pnpm run build" },
        "run_tests": { "command": "pnpm test" },
        "run_lint": { "command": "pnpm run lint-n-fix" },
        "run_single_test": { "command": "pnpm test" }
      }
    }
  },
  "middleware": [
    "anthropic-prompt-caching",
    {
      "name": "summarization",
      "maxTokensBeforeSummary": 12000
    }
  ]
}
