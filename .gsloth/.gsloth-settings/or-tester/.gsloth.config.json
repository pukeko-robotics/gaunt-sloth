{
  "llm": {
    "type": "openrouter",
    "model": "xiaomi/mimo-v2-flash:free"
  },
  "commands": {
    "ask": {
      "filesystem": "read",
      "builtInTools": {
        "gth_checklist": true,
        "run_build": { "command": "pnpm run build" },
        "run_tests": { "command": "pnpm test" },
        "run_lint": { "command": "pnpm run lint-n-fix" },
        "run_single_test": { "command": "pnpm test" }
      }
    }
  },
  "customTools": {
    "build": {
      "command": "bun build index.ts --outdir out",
      "description": "Run build with index.ts as entry-point"
    },
    "run_single_integration_test": {
      "command": "pnpm run it ${provider} ${testFileName}",
      "description": "Run single integration test from `integration-tests` dir",
      "parameters": {
        "provider": {
          "description": "AI provider name to run. Use `vertexai` unless something else is requested.`"
        },
        "testFileName": {
          "description": "Test file name to run"
        }
      }
    }
  }
}
