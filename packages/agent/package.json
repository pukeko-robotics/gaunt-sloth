    "@langchain/mcp-adapters": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "deepagents": "^1.10.2",
    "deepagents-acp": "^0.1.12",
    "diff": "^9.0.0",
    "express": "^5.2.1",
    "langchain": "^1.4.5"
