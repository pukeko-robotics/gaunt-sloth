{
  "name": "@gaunt-sloth/agent",
  "version": "0.1.8",
  "description": "Deep agent runtime for Gaunt Sloth: tools, middleware, MCP/A2A clients and the AG-UI server",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Galvanized-Pukeko/gaunt-sloth-assistant.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/Galvanized-Pukeko/gaunt-sloth-assistant/issues"
  },
  "homepage": "https://github.com/Galvanized-Pukeko/gaunt-sloth-assistant/tree/main/packages/agent#readme",
  "keywords": [
    "ai",
    "agent",
    "llm",
    "tools",
    "middleware",
    "ag-ui",
    "mcp",
    "a2a"
  ],
  "type": "module",
  "main": "dist/index.js",
