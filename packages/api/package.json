{
  "name": "@gaunt-sloth/api",
  "version": "0.2.0",
  "description": "API server for Gaunt Sloth",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pukeko-robotics/gaunt-sloth.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/pukeko-robotics/gaunt-sloth/issues"
  },
  "homepage": "https://github.com/pukeko-robotics/gaunt-sloth/tree/main/packages/api#readme",
  "keywords": [
    "ai",
    "agent",
    "llm",
    "api",
    "ag-ui",
    "mcp",
    "a2a"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gaunt-sloth-api": "cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*.js": "./dist/*.js"
  },
  "imports": {
    "#src/*.js": "./dist/*.js"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@ag-ui/core": "^0.0.57",
    "@ag-ui/encoder": "^0.0.57",
    "@gaunt-sloth/core": "0.2.0",
    "@gaunt-sloth/tools": "0.2.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1"
  },
  "files": [
    "./dist/*",
    "cli.js"
  ],
  "scripts": {
    "build": "tsc"
  }
}
